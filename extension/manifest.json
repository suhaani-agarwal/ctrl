{
  "manifest_version": 3,
  "name": "ctrl",
  "version": "2.0",
  "description": "Voice-first browser automation agent powered by Groq + Gemini Live",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "tabGroups",
    "sidePanel",
    "offscreen",
    "nativeMessaging",
    "debugger"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_title": "Open ctrl" },
  "side_panel": { "default_path": "sidepanel.html" },
  "web_accessible_resources": [
    {
      "resources": ["audio-processor.js", "offscreen.html", "skills/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}